{
	"$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!.next",
			"!drizzle",
			"!build",
			"!coverage",
			"!public",
			"!**/*.tsbuildinfo",
			"!**/pnpm-lock.yaml",
			"!next-env.d.ts",
			"!**/*.css"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100,
		"lineEnding": "lf"
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on",
				"useSortedKeys": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all",
			"arrowParentheses": "always",
			"bracketSpacing": true,
			"bracketSameLine": false
		}
	},
	"json": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		},
		"parser": {
			"allowComments": true,
			"allowTrailingCommas": false
		}
	},
	"css": {
		"linter": {
			"enabled": false
		},
		"formatter": {
			"enabled": false
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": "on",
			"complexity": {
				"recommended": true,
				"noExcessiveCognitiveComplexity": "off",
				"noExcessiveLinesPerFunction": "off"
			},
			"correctness": {
				"recommended": true,
				"noNodejsModules": "off",
				"noProcessGlobal": "off",
				"useExhaustiveDependencies": "error",
				"noUnusedImports": "error",
				"noUnusedVariables": "error",
				"noUnusedFunctionParameters": "error",
				"noUnusedPrivateClassMembers": "error"
			},
			"performance": {
				"recommended": true,
				"noBarrelFile": "off"
			},
			"security": {
				"recommended": true,
				"noSecrets": "off"
			},
			"style": {
				"recommended": true,
				"noDefaultExport": "off",
				"noMagicNumbers": "off",
				"noProcessEnv": "off",
				"noImplicitBoolean": "off",
				"noNestedTernary": "off",
				"noNonNullAssertion": "warn",
				"useConsistentArrayType": { "level": "error", "options": { "syntax": "shorthand" } },
				"useConsistentTypeDefinitions": { "level": "error", "options": { "style": "type" } },
				"useImportType": "error",
				"useExportType": "error",
				"useSelfClosingElements": "error",
				"useBlockStatements": "error",
				"useShorthandAssign": "error",
				"useCollapsedElseIf": "error",
				"useFragmentSyntax": "error",
				"useSingleVarDeclarator": "error",
				"useTemplate": "error"
			},
			"suspicious": {
				"recommended": true,
				"noConsole": { "level": "warn", "options": { "allow": ["error", "warn"] } },
				"noUnknownAtRules": "off"
			},
			"nursery": {
				"recommended": true,
				"noContinue": "off",
				"noExcessiveLinesPerFile": "off",
				"noInlineStyles": "off",
				"noTernary": "off",
				"useExplicitType": "off",
				"useExplicitReturnType": "off",
				"useBaseline": "off",
				"noMisusedPromises": "error",
				"useSortedClasses": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": [
				"app/**/route.{ts,tsx}",
				"app/**/page.{ts,tsx}",
				"app/**/layout.{ts,tsx}",
				"app/**/template.{ts,tsx}",
				"app/**/error.{ts,tsx}",
				"app/**/loading.{ts,tsx}",
				"app/**/not-found.{ts,tsx}",
				"middleware.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"useNamingConvention": "off",
						"useFilenamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.{ts,tsx}", "__tests__/**", "vitest.setup.ts", "vitest.config.ts"],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					}
				}
			}
		},
		{
			"includes": [
				"scripts/**",
				"migrate.ts",
				"proxy.ts",
				"drizzle.config.ts",
				"next.config.mjs",
				"postcss.config.mjs",
				"tailwind.config.ts",
				"vitest.config.ts"
			],
			"linter": {
				"rules": {
					"suspicious": {
						"noConsole": "off"
					},
					"style": {
						"noDefaultExport": "off",
						"useNamingConvention": "off"
					}
				}
			}
		},
		{
			"includes": ["package.json"],
			"formatter": {
				"indentStyle": "space",
				"indentWidth": 2
			}
		},
		{
			"includes": ["components/icons.tsx"],
			"linter": {
				"rules": {
					"a11y": {
						"noSvgWithoutTitle": "off"
					}
				}
			}
		}
	]
}
